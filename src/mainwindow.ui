  <property name="styleSheet">
   <string notr="true">/* --- Styl dla głównego okna --- */
QMainWindow {
    background-color: #2a0a1a; /* Bardzo ciemny, bordowy fiolet */
    color: #fce4ec; /* Jasny, pudrowy róż dla napisów */
}

/* --- Styl dla pól tekstowych (input/output) --- */
QTextEdit {
    background-color: #3e1e2d; /* Ciemny, nasycony różowo-bordowy */
    color: #fce4ec; /* Jasny, pudrowy róż dla tekstu */
    border: 1px solid #ff4081; /* Jaskrawy różowy brzeg */
    border-radius: 8px;
    padding: 10px;
    selection-background-color: #e91e63; /* Intensywny różowy dla zaznaczenia */
    selection-color: white;
}

/* --- Styl dla przycisku (Zredaguj tekst) --- */
QPushButton {
    background-color: #ff4081; /* Jaskrawy, nasycony różowy */
    color: white;
    border: none;
    border-radius: 8px;
    padding: 10px 20px;
    font-weight: bold;
    min-width: 150px;
}

QPushButton:hover {
    background-color: #ff80ab; /* Jaśniejszy, pudrowy róż po najechaniu */
}

QPushButton:pressed {
    background-color: #e91e63; /* Ciemniejszy, intensywny różowy po kliknięciu */
}

/* --- Styl dla listy rozwijanej (styleCombo) --- */
QComboBox {
    background-color: #3e1e2d; /* Ciemny, nasycony różowo-bordowy */
    color: #fce4ec; /* Jasny, pudrowy róż dla tekstu */
    border: 1px solid #ff4081; /* Jaskrawy różowy brzeg */
    border-radius: 8px;
    padding: 8px;
}

QComboBox QAbstractItemView {
    background-color: #3e1e2d; /* Ciemny, nasycony różowo-bordowy dla listy */
    color: #fce4ec; /* Jasny, pudrowy róż dla opcji */
    selection-background-color: #e91e63; /* Intensywny różowy dla wybranej opcji */
    selection-color: white;
}

/* --- Styl dla etykiety statusu --- */
QLabel {
    color: #ff80ab; /* Pudrowy róż dla statusu */
    background: transparent;
}</string>
